{
  "name": "re-entry",
  "private": true,
  "version": "0.9.0",
  "description": "Leave a project well. Come back to a letter, not a pile.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "reentry": "cli/reentry.ts"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "test": "node --test",
    "test:e2e": "node tests/e2e.mjs",
    "reentry": "node cli/reentry.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "puppeteer-core": "^25.3.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
